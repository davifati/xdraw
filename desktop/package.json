{
  "name": "xdraw",
  "version": "1.0.0",
  "description": "Architecture drawing tool based on Excalidraw",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --universal",
    "build:arm64": "electron-builder --mac --arm64",
    "build:x64": "electron-builder --mac --x64"
  },
  "build": {
    "appId": "com.local.xdraw",
    "productName": "xDraw",
    "copyright": "Copyright © 2024 David Lima",
    "directories": {
      "output": "../dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "../excalidraw-app/build",
        "to": "build",
        "filter": [
          "**/*",
          "!**/*.map"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        { "x": 130, "y": 220, "type": "file" },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  }
}
